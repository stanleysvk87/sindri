# cp .env.example .env  a uprav

# Prihlasovacie heslo do appky (jedno zdieľané heslo, žiadny multi-user zatiaľ)
SINDRI_PASSWORD=zmen-ma

# Port na hostiteľovi, kde appka pobeží (http://localhost:PORT)
SINDRI_PORT=8420

# Vzdialené spustenie skriptov cez SSH na registrované stroje (pozri
# docs/REMOTE_EXEC.md) — vyžaduje aj mount SSH kľúčov v docker-compose.yml.
# Sudo heslo (ak ho skript potrebuje) sa zadáva pri každom spustení
# zvlášť v UI, nikdy sa neukladá.
SINDRI_REMOTE_EXEC_ENABLED=false

# AI generovanie/review (voliteľné, appka funguje aj bez toho) — pozri
# docs/AI_FEATURES.md. "auto" skúša claude CLI, potom codex CLI, potom
# tento API kľúč, podľa toho čo je na hostiteľovi/kontajneri dostupné.
SINDRI_AI_PROVIDER_MODE=auto
SINDRI_ANTHROPIC_API_KEY=

# Sandbox testovanie skriptov (voliteľné) — vyžaduje aj odkomentovaný
# docker.sock mount v docker-compose.yml. Pozri docs/SANDBOX.md pred
# zapnutím, je to reálny trade-off (host-root-ekvivalentný prístup pre
# backend), nie len prepínač.
SINDRI_SANDBOX_ENABLED=false

# cp .env.example .env  and edit

# App login password (one shared password, no multi-user yet)
SINDRI_PASSWORD=change-me

# Port on the host where the app runs (http://localhost:PORT)
SINDRI_PORT=8420

# Remote script execution over SSH to registered machines (see
# docs/REMOTE_EXEC.md) -- also requires the SSH key mount in
# docker-compose.yml. The sudo password (if the script needs it) is
# entered fresh in the UI on every run, never stored.
SINDRI_REMOTE_EXEC_ENABLED=false

# AI generation/review (optional, the app works fully without it) --
# see docs/AI_FEATURES.md. "auto" tries the claude CLI, then the codex
# CLI, then this API key, whichever is actually available on the host/
# container.
SINDRI_AI_PROVIDER_MODE=auto
SINDRI_ANTHROPIC_API_KEY=

# Sandbox script testing (optional) -- also requires uncommenting the
# docker.sock mount in docker-compose.yml. Read docs/SANDBOX.md before
# enabling this, it's a real trade-off (host-root-equivalent access for
# the backend), not just a toggle.
SINDRI_SANDBOX_ENABLED=false

# Only if SINDRI_SANDBOX_ENABLED=true: the GID of the "docker" group on
# THIS host, found via `getent group docker | cut -d: -f3` (this
# differs machine to machine, it is not a universal value). Without
# this, the backend has no access to /var/run/docker.sock even with the
# mount uncommented -- see docs/SANDBOX.md.
SINDRI_DOCKER_GID=999

# Colon-separated list of container paths that local scan/import
# (backend/app/import_utils.py) is allowed to reach. Defaults to just
# the bind-mounted import-sources folder -- change this only if you
# also add extra bind mounts elsewhere in docker-compose.yml, and keep
# it as narrow as the paths you actually intend to scan.
SINDRI_IMPORT_ALLOWED_ROOTS=/import-sources
